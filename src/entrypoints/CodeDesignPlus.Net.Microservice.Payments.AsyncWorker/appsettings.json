{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5000",
        "Protocols": "Http1"
      }
    }
  },
  "Core": {
    "AppName": "ms-payments",
    "TypeEntryPoint": "worker",
    "Version": "v1",
    "Description": "Custom Microservice",
    "Business": "CodeDesignPlus",
    "Contact": {
      "Name": "CodeDesignPlus",
      "Email": "support@codedesignplus.com"
    }
  },
  "Security": {
    "ClientId": "a74cb192-598c-4757-95ae-b315793bbbca",
    "IncludeErrorDetails": true,
    "ValidateAudience": true,
    "ValidateIssuer": true,
    "ValidateLifetime": true,
    "RequireHttpsMetadata": true,
    "ValidIssuer": "",
    "ValidAudiences": [
      "a74cb192-598c-4757-95ae-b315793bbbca"
    ],
    "Applications": []
  },
  "Redis": {
    "Instances": {
      "Core": {
        "ConnectionString": "localhost:6379"
      }
    }
  },
  "RedisCache": {
    "Enable": true,
    "Expiration": "00:05:00"
  },
  "RabbitMQ": {
    "Enable": true,
    "Host": "localhost",
    "Port": 5672,
    "UserName": "admin",
    "Password": "password",
    "EnableDiagnostic": true,
    "UseQueue": false
  },
  "Mongo": {
    "Enable": true,
    "ConnectionString": "mongodb://localhost:27017",
    "Database": "db-ms-payments",
    "Diagnostic": {
      "Enable": false,
      "EnableCommandText": false
    }
  },
  "Logger": {
    "Enable": true,
    "OTelEndpoint": "http://127.0.0.1:4317"
  },
  "Observability": {
    "Enable": true,
    "ServerOtel": "http://127.0.0.1:4317",
    "Trace": {
      "Enable": true,
      "AspNetCore": true,
      "GrpcClient": false,
      "SqlClient": false,
      "CodeDesignPlusSdk": true,
      "Redis": true,
      "Kafka": false,
      "RabbitMQ": true
    },
    "Metrics": {
      "Enable": true,
      "AspNetCore": true
    }
  },
  "Vault": {
    "Enable": true,
    "Address": "http://localhost:8200",
    "AppName": "ms-payments",
    "Solution": "security-codedesignplus",
    "Token": "root",
    "Mongo": {
      "Enable": true,
      "TemplateConnectionString": "mongodb://{0}:{1}@localhost:27017"
    },
    "RabbitMQ": {
      "Enable": true
    }
  },
  "Payu": {
    "Enable": true,
    "Url": "https://sandbox.api.payulatam.com",
    "IsTest": true,
    "Language": "en",
    "Currency": "COP",
    "NotificationUrl": "https://services.kappali.com/ms-payments/api/payment/notify",
    "Resilience": {
      "Enable": true,
      "MaxRetryAttempts": 3,
      "RetryBaseDelaySeconds": 2.0,
      "RetryMaxDelaySeconds": 10.0,
      "CircuitBreakerFailureRatio": 0.5,
      "CircuitBreakerMinimumThroughput": 10,
      "CircuitBreakerBreakDurationSeconds": 30.0,
      "CircuitBreakerSamplingDurationSeconds": 60.0,
      "TimeoutSeconds": 15.0,
      "RetryOnProviderSoftErrors": true,
      "MaxSoftErrorRetryAttempts": 6,
      "SoftErrorRetryBaseDelaySeconds": 2.0,
      "SoftErrorMaxDelaySeconds": 5.0
    }
  },
  "GrpcClients": {
    "Payment": "http://ms-payments-grpc.kappali.svc.cluster.local:5001",
    "User": "http://ms-users-grpc.kappali.svc.cluster.local:5001",
    "Tenant": "http://ms-tenants-grpc.kappali.svc.cluster.local:5001",
    "Notification": "http://ms-notification-grpc.kappali.svc.cluster.local:5001",
    "Location": "http://ms-locations-grpc.kappali.svc.cluster.local:5001"
  }
}
